{
  "name": "dnscope",
  "version": "0.1.0",
  "private": true,
  "description": "A fast, privacy-first desktop DNS benchmark and record inspector.",
  "author": "Horatio Xu",
  "license": "MIT",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -s first \"vite --host 127.0.0.1\" \"wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "generate:icons": "node scripts/generate-icons.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node --test tests/*.test.cjs",
    "check": "npm run test && npm run build",
    "dist": "npm run generate:icons && npm run build && electron-builder --publish never",
    "dist:win": "npm run generate:icons && npm run build && electron-builder --win nsis --x64 --publish never",
    "dist:mac": "npm run generate:icons && npm run build && electron-builder --mac dmg --publish never",
    "dist:linux": "npm run generate:icons && npm run build && electron-builder --linux AppImage --publish never"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "io.github.hhhoratioxu.dnscope",
    "productName": "DNScope",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "DNScope-${version}-Windows-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "icon": "assets/icon.png",
      "target": "dmg",
      "category": "public.app-category.utilities",
      "artifactName": "DNScope-${version}-macOS-${arch}.${ext}"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": "AppImage",
      "category": "Network",
      "artifactName": "DNScope-${version}-Linux-${arch}.${ext}"
    }
  }
}
